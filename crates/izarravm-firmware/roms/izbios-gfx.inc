; izbios-gfx.inc - foundation: VGA mode 13h drawing primitives + the 8x8 CP437
; font (a byte-for-byte copy of izarravm-video VGAFONT_8X8; a Rust spot-check
; guards against drift). Pixels go to A000:offset, offset = y*320 + x; the
; emulator routes the chain-4 write to the linear 320x200 buffer. All routines
; preserve caller registers (no documented return values here).

; set_mode13h: install chained 256-color mode 13h via INT 10h.
set_mode13h:
    push ax
    mov ax, 0x0013
    int 0x10
    pop ax
    ret

; gfx_clear: fill the whole frame with color AL.
gfx_clear:
    push es
    push di
    push cx
    push ax
    mov ah, al              ; replicate the color into both bytes of AX
    mov cx, VGA13_SEG
    mov es, cx
    xor di, di
    mov cx, 32000           ; 64000 bytes / 2
    rep stosw
    pop ax
    pop cx
    pop di
    pop es
    ret

; gfx_fill_rect: DI=x, SI=y, CX=w, DX=h, BL=color.
gfx_fill_rect:
    pusha
    push es
    mov ax, VGA13_SEG
    mov es, ax
    mov bp, di              ; bp = x
.row:
    test dx, dx
    jz .done
    push dx                 ; rows remaining
    push cx                 ; width
    mov ax, si
    mov dx, 320
    mul dx                  ; ax = y*320 (y < 200, so dx = 0)
    add ax, bp
    mov di, ax              ; ES:DI = row start
    pop cx                  ; width
    mov al, bl              ; color
    rep stosb
    pop dx                  ; rows remaining
    inc si                  ; next scanline
    dec dx
    jmp .row
.done:
    pop es
    popa
    ret

; gfx_text: DS:SI=ASCIIZ, DI=x, AX=y, BL=fg, BH=bg. 8 px advance per glyph.
gfx_text:
    pusha
    push es
    mov bp, di              ; bp = x
    mov dx, 320
    mul dx                  ; ax = y*320
    add ax, bp
    mov di, ax              ; ES:DI = glyph top-left
    mov ax, VGA13_SEG
    mov es, ax
.char_loop:
    mov al, [si]
    test al, al
    jz .done
    inc si
    call gfx_glyph
    add di, 8
    jmp .char_loop
.done:
    pop es
    popa
    ret

; gfx_glyph: draw one 8x8 glyph. AL=char, ES:DI=top-left, BL=fg, BH=bg.
; Preserves SI, DI, BX; scratches AX, CX, DX, BP.
gfx_glyph:
    push si
    push di
    push cx
    push dx
    push bp
    movzx si, al
    shl si, 3               ; char * 8
    add si, bios_font       ; CS:SI -> 8 font bytes
    mov dx, di              ; dx = scanline destination base
    mov cx, 8
.row:
    push cx
    mov al, [cs:si]
    inc si
    mov bp, dx              ; bp = pixel destination for this row
    mov cx, 8
.col:
    shl al, 1               ; MSB -> CF
    jc .fg
    mov ah, bh              ; background
    jmp .put
.fg:
    mov ah, bl              ; foreground
.put:
    mov [es:bp], ah
    inc bp
    loop .col
    pop cx
    add dx, 320
    loop .row
    pop bp
    pop dx
    pop cx
    pop di
    pop si
    ret

; gfx_putdec: AX=value, DI=x, SI=y, BL=fg, BH=bg. Fixed 5-digit zero-padded.
gfx_putdec:
    pusha
    push es
    push ds
    push di                 ; x
    push si                 ; y
    push bx                 ; colors
    xor cx, cx
    mov ds, cx              ; DS = 0 (BIOS_VALBUF lives in segment 0)
    mov di, BIOS_VALBUF + 5
    mov byte [di], 0
    mov cx, 5
    mov bx, 10
.digit:
    dec di
    xor dx, dx
    div bx                  ; AX /= 10, DX = remainder
    add dl, '0'
    mov [di], dl
    loop .digit
    mov si, di              ; DS:SI -> 5-digit string
    pop bx                  ; colors
    pop ax                  ; y
    pop di                  ; x
    call gfx_text
    pop ds
    pop es
    popa
    ret

; gfx_puthex: AX=value, DI=x, SI=y, BL=fg, BH=bg. Fixed 4 hex digits (lowercase).
gfx_puthex:
    pusha
    push es
    push ds
    push di
    push si
    push bx
    xor cx, cx
    mov ds, cx
    mov di, BIOS_VALBUF
    mov bp, ax              ; value
    mov cx, 4
.nib:
    rol bp, 4               ; bring the next high nibble into bits 3-0
    mov ax, bp
    and al, 0x0f
    cmp al, 10
    jb .dec
    add al, 'a' - 10
    jmp .store
.dec:
    add al, '0'
.store:
    mov [di], al
    inc di
    loop .nib
    mov byte [di], 0
    mov si, BIOS_VALBUF
    pop bx
    pop ax                  ; y
    pop di                  ; x
    call gfx_text
    pop ds
    pop es
    popa
    ret

; gfx_set_palette: BX=DAC index, DH=R (6-bit), CH=G, CL=B. INT 10h AH=10h AL=10h.
gfx_set_palette:
    push ax
    mov ax, 0x1010
    int 0x10
    pop ax
    ret

; status_panel_draw: enter mode 13h, clear, draw the POST title. Sets DS = CS.
status_panel_draw:
    call set_mode13h
    mov al, COLOR_BG
    call gfx_clear
    push cs
    pop ds
    mov si, str_post_title
    mov di, STATUS_X
    mov ax, STATUS_TITLE_Y
    mov bl, COLOR_TITLE
    mov bh, COLOR_BG
    call gfx_text
    ret
str_post_title: db 'IZARRA 3000 POST', 0

; console_init: enter mode 13h, clear, draw the boot-console title, and reset the
; console row. Called once at the start of POST so the main window shows a boot log.
console_init:
    call set_mode13h
    mov al, COLOR_BG
    call gfx_clear
    push cs
    pop ds
    mov si, str_console_title
    mov di, STATUS_X
    mov ax, STATUS_TITLE_Y
    mov bl, COLOR_TITLE
    mov bh, COLOR_BG
    call gfx_text
    xor ax, ax
    mov ds, ax
    mov word [CONSOLE_ROW_Y], STATUS_Y
    ret
str_console_title: db 'IZARRA 3000 BIOS   POWER-ON SELF TEST', 0

; console_step_line: draw one boot-log line and advance the console row. SI = step
; name (CS-relative ROM ptr), AL = handler status (HRES_PASS/FAIL/MEASURE), DX =
; segment-0 offset of the ASCIIZ value (MEASURE only). CL, DX, SI and BP survive
; gfx_text (its pusha/popa), so they carry state across the two draws. Preserves
; all caller registers.
console_step_line:
    push ax
    push bx
    push cx
    push dx
    push si
    push di
    push bp
    push ds
    mov cl, al                  ; CL = status (survives gfx_text)
    xor ax, ax
    mov ds, ax
    mov bp, [CONSOLE_ROW_Y]     ; BP = row Y (survives gfx_text)
    push cs
    pop ds                      ; DS = CS for the ROM name string
    mov di, STATUS_X
    mov ax, bp
    mov bx, COLOR_INFO          ; bl = grey, bh = 0
    call gfx_text               ; SI still = name afterward
    cmp cl, HRES_MEASURE
    je .measure
    cmp cl, HRES_FAIL
    je .fail
    push cs
    pop ds
    mov si, str_ok
    mov bx, COLOR_PASS
    jmp .draw
.fail:
    push cs
    pop ds
    mov si, str_fail
    mov bx, COLOR_FAIL
    jmp .draw
.measure:
    xor ax, ax
    mov ds, ax                  ; the value lives in segment 0
    mov si, dx
    mov bx, COLOR_MEASURE
.draw:
    mov di, STATUS_VALUE_X
    mov ax, bp
    call gfx_text
    xor ax, ax
    mov ds, ax
    add bp, STATUS_LINE_DY
    mov [CONSOLE_ROW_Y], bp
    pop ds
    pop bp
    pop di
    pop si
    pop dx
    pop cx
    pop bx
    pop ax
    ret
str_ok:   db 'OK', 0
str_fail: db 'FAIL', 0

