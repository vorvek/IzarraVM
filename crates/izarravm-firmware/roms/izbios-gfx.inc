; izbios-gfx.inc - foundation: VGA mode 13h drawing primitives + the 8x8 CP437
; font (a byte-for-byte copy of izarravm-video VGAFONT_8X8; a Rust spot-check
; guards against drift). Pixels go to A000:offset, offset = y*320 + x; the
; emulator routes the chain-4 write to the linear 320x200 buffer. All routines
; preserve caller registers (no documented return values here).

; set_mode13h: install chained 256-color mode 13h via INT 10h.
set_mode13h:
    push ax
    mov ax, 0x0013
    int 0x10
    pop ax
    ret

; gfx_clear: fill the whole frame with color AL.
gfx_clear:
    push es
    push di
    push cx
    push ax
    mov ah, al              ; replicate the color into both bytes of AX
    mov cx, VGA13_SEG
    mov es, cx
    xor di, di
    mov cx, 32000           ; 64000 bytes / 2
    rep stosw
    pop ax
    pop cx
    pop di
    pop es
    ret

; gfx_fill_rect: DI=x, SI=y, CX=w, DX=h, BL=color.
gfx_fill_rect:
    pusha
    push es
    mov ax, VGA13_SEG
    mov es, ax
    mov bp, di              ; bp = x
.row:
    test dx, dx
    jz .done
    push dx                 ; rows remaining
    push cx                 ; width
    mov ax, si
    mov dx, 320
    mul dx                  ; ax = y*320 (y < 200, so dx = 0)
    add ax, bp
    mov di, ax              ; ES:DI = row start
    pop cx                  ; width
    mov al, bl              ; color
    rep stosb
    pop dx                  ; rows remaining
    inc si                  ; next scanline
    dec dx
    jmp .row
.done:
    pop es
    popa
    ret

; gfx_text: DS:SI=ASCIIZ, DI=x, AX=y, BL=fg, BH=bg. 8 px advance per glyph.
gfx_text:
    pusha
    push es
    mov bp, di              ; bp = x
    mov dx, 320
    mul dx                  ; ax = y*320
    add ax, bp
    mov di, ax              ; ES:DI = glyph top-left
    mov ax, VGA13_SEG
    mov es, ax
.char_loop:
    mov al, [si]
    test al, al
    jz .done
    inc si
    call gfx_glyph
    add di, 8
    jmp .char_loop
.done:
    pop es
    popa
    ret

; gfx_glyph: draw one 8x8 glyph. AL=char, ES:DI=top-left, BL=fg, BH=bg.
; Preserves SI, DI, BX; scratches AX, CX, DX, BP.
gfx_glyph:
    push si
    push di
    push cx
    push dx
    push bp
    movzx si, al
    shl si, 3               ; char * 8
    add si, bios_font       ; CS:SI -> 8 font bytes
    mov dx, di              ; dx = scanline destination base
    mov cx, 8
.row:
    push cx
    mov al, [cs:si]
    inc si
    mov bp, dx              ; bp = pixel destination for this row
    mov cx, 8
.col:
    shl al, 1               ; MSB -> CF
    jc .fg
    mov ah, bh              ; background
    jmp .put
.fg:
    mov ah, bl              ; foreground
.put:
    mov [es:bp], ah
    inc bp
    loop .col
    pop cx
    add dx, 320
    loop .row
    pop bp
    pop dx
    pop cx
    pop di
    pop si
    ret

; gfx_putdec: AX=value, DI=x, SI=y, BL=fg, BH=bg. Fixed 5-digit zero-padded.
gfx_putdec:
    pusha
    push es
    push ds
    push di                 ; x
    push si                 ; y
    push bx                 ; colors
    xor cx, cx
    mov ds, cx              ; DS = 0 (BIOS_VALBUF lives in segment 0)
    mov di, BIOS_VALBUF + 5
    mov byte [di], 0
    mov cx, 5
    mov bx, 10
.digit:
    dec di
    xor dx, dx
    div bx                  ; AX /= 10, DX = remainder
    add dl, '0'
    mov [di], dl
    loop .digit
    mov si, di              ; DS:SI -> 5-digit string
    pop bx                  ; colors
    pop ax                  ; y
    pop di                  ; x
    call gfx_text
    pop ds
    pop es
    popa
    ret

; gfx_puthex: AX=value, DI=x, SI=y, BL=fg, BH=bg. Fixed 4 hex digits (lowercase).
gfx_puthex:
    pusha
    push es
    push ds
    push di
    push si
    push bx
    xor cx, cx
    mov ds, cx
    mov di, BIOS_VALBUF
    mov bp, ax              ; value
    mov cx, 4
.nib:
    rol bp, 4               ; bring the next high nibble into bits 3-0
    mov ax, bp
    and al, 0x0f
    cmp al, 10
    jb .dec
    add al, 'a' - 10
    jmp .store
.dec:
    add al, '0'
.store:
    mov [di], al
    inc di
    loop .nib
    mov byte [di], 0
    mov si, BIOS_VALBUF
    pop bx
    pop ax                  ; y
    pop di                  ; x
    call gfx_text
    pop ds
    pop es
    popa
    ret

; gfx_set_palette: BX=DAC index, DH=R (6-bit), CH=G, CL=B. INT 10h AH=10h AL=10h.
gfx_set_palette:
    push ax
    mov ax, 0x1010
    int 0x10
    pop ax
    ret

; status_panel_draw: enter mode 13h, clear, draw the POST title. Sets DS = CS.
status_panel_draw:
    call set_mode13h
    mov al, COLOR_BG
    call gfx_clear
    push cs
    pop ds
    mov si, str_post_title
    mov di, STATUS_X
    mov ax, STATUS_TITLE_Y
    mov bl, COLOR_TITLE
    mov bh, COLOR_BG
    call gfx_text
    ret
str_post_title: db 'IZARRA 3000 POST', 0

; console_init: paint the graceful POST screen (white field, red Izarra 3000
; wordmark, black title and hint lines, empty progress bar). Called once at the
; start of POST. The per-step boot log moves to COM1; the on-screen experience is
; the graphical screen plus the RAM count-up, not a scrolling text log.
console_init:
    call gfx_post_screen
    xor ax, ax
    mov ds, ax
    mov word [CONSOLE_ROW_Y], POST_HINT_Y
    ret

; console_step_line: per-step screen hook. Lights the matching component icon
; grey->colour when its probe PASSes, by blitting the colour sprite over the grey
; icon already in the background. The sequencer calls this once per step with
; AL = status (HRES_PASS/FAIL/MEASURE), SI = CS-relative step-name pointer, and
; DS = 0. The per-step PASS/FAIL log is mirrored to COM1 separately. It preserves
; ALL caller registers so the sequencer's name pointer in SI and status in AL
; survive across the call (the COM1 mirror and result_append run after it).
console_step_line:
    cmp al, HRES_PASS
    jne .ret                        ; only a PASS lights its icon
    pusha
    mov bx, icon_map
.scan:
    cmp bx, icon_map_end
    jae .scan_done
    mov di, [cs:bx]                 ; candidate step-name pointer (ROM)
    call cs_streq                   ; compare CS:SI vs CS:DI -> ZF=1 if equal
    je .hit
    add bx, 12                      ; next row (6 words)
    jmp .scan
.hit:
    mov si, [cs:bx + 2]             ; colour-sprite RLE pointer
    mov di, [cs:bx + 4]             ; cell x
    mov ax, [cs:bx + 6]             ; cell y
    mov cx, [cs:bx + 8]             ; cell w
    mov dx, [cs:bx + 10]            ; cell h
    call lfb_blit_rle               ; reads CS:SI (SI is in ROM); resets DS itself
.scan_done:
    popa
.ret:
    ret

; icon_map: each wired component, mapped step-name -> colour sprite + cell. A row
; is  dw step_name_ptr, dw sprite_rle_ptr, dw cell_x, cell_y, cell_w, cell_h
; (6 words = 12 bytes). All 7 icons are wired: VEGA/RAM/sound (Phase 2) and
; CPU/floppy/HDD/optical (Phase 3). An absent device's probe FAILs, so its icon
; stays grey (e.g. HDD when C: is HLE-backed rather than a real ATA disk).
icon_map:
    dw icon_name_video,   art_icon_0_rle, ICON_0_X, ICON_0_Y, ICON_0_W, ICON_0_H
    dw icon_name_cpu,     art_icon_1_rle, ICON_1_X, ICON_1_Y, ICON_1_W, ICON_1_H
    dw icon_name_ram,     art_icon_2_rle, ICON_2_X, ICON_2_Y, ICON_2_W, ICON_2_H
    dw icon_name_sbdsp,   art_icon_3_rle, ICON_3_X, ICON_3_Y, ICON_3_W, ICON_3_H
    dw icon_name_floppy,  art_icon_4_rle, ICON_4_X, ICON_4_Y, ICON_4_W, ICON_4_H
    dw icon_name_hdd,     art_icon_5_rle, ICON_5_X, ICON_5_Y, ICON_5_W, ICON_5_H
    dw icon_name_optical, art_icon_6_rle, ICON_6_X, ICON_6_Y, ICON_6_W, ICON_6_H
icon_map_end:
icon_name_video:   db 'component.video_margo', 0
icon_name_cpu:     db 'component.cpu_gsw', 0
icon_name_ram:     db 'memory.ramtest', 0
icon_name_sbdsp:   db 'component.audio_sbdsp', 0
icon_name_floppy:  db 'component.floppy_fdc', 0
icon_name_hdd:     db 'component.disk_hdd', 0
icon_name_optical: db 'component.optical_atapi', 0

; cs_streq: compare the ASCIIZ strings at CS:SI and CS:DI. Returns ZF=1 if equal,
; ZF=0 otherwise. Preserves SI, DI and AX (it walks copies on the stack).
cs_streq:
    push si
    push di
    push ax
.next:
    mov al, [cs:si]
    cmp al, [cs:di]
    jne .done                       ; mismatch -> ZF=0
    test al, al
    jz .done                        ; both reached NUL together -> ZF=1
    inc si
    inc di
    jmp .next
.done:
    pop ax
    pop di
    pop si
    ret

; --- Graceful POST screen primitives ---------------------------------------
; The boot screen is an Amiga/Mac-style white field with black text, a red
; "Izarra 3000" wordmark across the top, and a red progress bar for the RAM
; test. The palette below repaints three DAC slots so gfx_clear/gfx_text/the
; blit all reach those exact colors regardless of the mode-13h defaults.

; gfx_post_palette: program the three boot-screen DAC slots (white background,
; black text, red accent). Uses INT 10h AH=10h AL=10h per slot. R/G/B are 6-bit.
gfx_post_palette:
    push ax
    push bx
    push cx
    push dx
    mov bx, GFX_WHITE           ; index 0 -> full white
    mov dh, 63
    mov ch, 63
    mov cl, 63
    call gfx_set_palette
    mov bx, GFX_BLACK           ; index 1 -> black
    xor dh, dh
    xor ch, ch
    xor cl, cl
    call gfx_set_palette
    mov bx, GFX_RED             ; index 4 -> pure red
    mov dh, 63
    xor ch, ch
    xor cl, cl
    call gfx_set_palette
    pop dx
    pop cx
    pop bx
    pop ax
    ret

; gfx_blit_1bpp: draw a 1-bpp ROM bitmap, set bits painted in color BL, clear
; bits left alone so the background shows through. CS:SI = bitmap top row,
; DI = x, AX = y, CX = width in pixels, DX = height in rows, BH = stride (bytes
; per source row). Geometry lives in segment-0 scratch (BLIT_*) so the inner
; loops keep their registers free. The set-bit-only blit keeps the white field
; intact around the red wordmark.
gfx_blit_1bpp:
    pusha
    push es
    push ds
    ; Stash the geometry into segment-0 scratch.
    push ax                     ; save y for the scratch store
    xor ax, ax
    mov ds, ax                  ; DS = 0 for the scratch words
    mov [BLIT_X], di
    mov [BLIT_W], cx
    mov [BLIT_H], dx
    mov [BLIT_COLOR], bl
    movzx bx, bh
    mov [BLIT_STRIDE], bx
    pop ax                      ; restore y
    mov [BLIT_Y], ax
    mov ax, VGA13_SEG
    mov es, ax                  ; ES = framebuffer
.row_loop:
    xor ax, ax
    mov ds, ax
    mov dx, [BLIT_H]
    test dx, dx
    jz .done
    ; Row start offset = y*320 + x.
    mov ax, [BLIT_Y]
    mov bx, 320
    mul bx                      ; AX = y*320 (y<200, DX=0)
    add ax, [BLIT_X]
    mov di, ax                  ; ES:DI = first pixel of this scanline
    xor bp, bp                  ; BP = pixel column (survives the shift work)
.col_loop:
    cmp bp, [BLIT_W]            ; DS=0 here from the row setup
    jae .row_end
    ; bit = source[col>>3], MSB first within the byte.
    mov bx, bp
    shr bx, 3                   ; byte index in the source row
    add bx, si                  ; CS:BX -> source byte
    mov al, [cs:bx]
    mov cx, bp
    and cl, 7
    mov ah, 7
    sub ah, cl                  ; AH = bit position (7..0)
    mov cl, ah
    shr al, cl                  ; the target bit drops to bit 0
    test al, 1
    jz .skip
    mov ah, [BLIT_COLOR]
    mov [es:di], ah
.skip:
    inc di
    inc bp
    jmp .col_loop
.row_end:
    mov ax, [BLIT_Y]
    inc ax
    mov [BLIT_Y], ax
    mov ax, [BLIT_STRIDE]
    add si, ax                  ; advance source to the next row
    dec word [BLIT_H]
    jmp .row_loop
.done:
    pop ds
    pop es
    popa
    ret

; gfx_post_screen: paint the graphical POST screen from the RLE art. Loads the
; shared palette into the DAC, blits the grey background (the wordmark, mascot and
; grey component icons are all baked into it), then draws the two top-left header
; lines (version + "Starting your computer..."). The component icons light from
; grey to colour later, one per probe, in console_step_line. Called once before
; the RAM test paces. Drawing is done into VRAM before lfb_set_mode (activate
; last): Margo's set_mode does not clear VRAM, so flipping the order would make
; the mode switch visible while VRAM still holds stale pixels (a flash of
; garbage). Do NOT move lfb_set_mode earlier -- the screen would no longer reveal
; atomically.
gfx_post_screen:
    call lfb_load_palette           ; shared art palette -> VGA DAC (Margo reads it)
    ; Grey background: the full-screen RLE blob (320x240 indexed art).
    push cs
    pop ds
    mov si, art_bg_rle
    xor di, di
    xor ax, ax
    mov cx, LFB_W
    mov dx, LFB_H
    call lfb_blit_rle
    ; Header line 1: the version string, ink on the cream field, top-left.
    push cs
    pop ds
    mov si, str_post_name
    mov di, ART_HDR_X
    mov ax, ART_VER_Y
    mov bl, ART_INK_INDEX
    mov bh, ART_FIELD_INDEX
    call lfb_text
    ; Header line 2: the running-diagnostics status.
    push cs
    pop ds
    mov si, str_post_starting
    mov di, ART_HDR_X
    mov ax, ART_START_Y
    mov bl, ART_INK_INDEX
    mov bh, ART_FIELD_INDEX
    call lfb_text
    ; Key hints (DEL/TAB) in the gap above the icon row, ink on the field.
    push cs
    pop ds
    mov si, str_post_hint1
    mov di, ART_HDR_X
    mov ax, ART_HINT1_Y
    mov bl, ART_INK_INDEX
    mov bh, ART_FIELD_INDEX
    call lfb_text
    push cs
    pop ds
    mov si, str_post_hint2
    mov di, ART_HDR_X
    mov ax, ART_HINT2_Y
    mov bl, ART_INK_INDEX
    mov bh, ART_FIELD_INDEX
    call lfb_text
    call lfb_set_mode               ; proprietary 320x240x8 Margo mode (activate last)
    ret

; gfx_bar_frame: draw the red outline of the RAM progress bar (top, bottom, and
; both sides), leaving the interior white for the fill to grow into.
gfx_bar_frame:
    push di
    push si
    push cx
    push dx
    push bx
    mov bl, GFX_RED
    ; top edge
    mov di, POST_BAR_X
    mov si, POST_BAR_Y
    mov cx, POST_BAR_W
    mov dx, 1
    call lfb_fill_rect
    ; bottom edge
    mov di, POST_BAR_X
    mov si, POST_BAR_Y + POST_BAR_H - 1
    mov cx, POST_BAR_W
    mov dx, 1
    call lfb_fill_rect
    ; left edge
    mov di, POST_BAR_X
    mov si, POST_BAR_Y
    mov cx, 1
    mov dx, POST_BAR_H
    call lfb_fill_rect
    ; right edge
    mov di, POST_BAR_X + POST_BAR_W - 1
    mov si, POST_BAR_Y
    mov cx, 1
    mov dx, POST_BAR_H
    call lfb_fill_rect
    pop bx
    pop dx
    pop cx
    pop si
    pop di
    ret

; gfx_bar_fill: AX = percent (0..100). The graphical POST art has no progress bar
; -- the grey->colour icon reveal is the progress indicator -- so this is a no-op.
; The RAM test (ramtest_draw) still calls it by name; keep the label and just
; return. ponytail: stub, not dead code -- ramtest-core owns its call site.
gfx_bar_fill:
    ret

; gfx_post_mem: draw the "Testing memory: NNNNN KB" line with KiB value in AX.
; The count-up calls this each step with a rising value; it overwrites the prior
; number by repainting the whole line on the white field.
gfx_post_mem:
    pusha
    push ax                         ; save the KiB value
    ; Repaint the line's background with the field colour to erase the prior number.
    mov di, ART_HDR_X
    mov si, ART_MEM_Y
    mov cx, 256
    mov dx, 8
    mov bl, ART_FIELD_INDEX
    call lfb_fill_rect
    ; Label.
    push cs
    pop ds
    mov si, str_post_mem
    mov di, ART_HDR_X
    mov ax, ART_MEM_Y
    mov bl, ART_INK_INDEX
    mov bh, ART_FIELD_INDEX
    call lfb_text
    ; Number (5-digit, ink on field), placed after the label.
    pop ax                          ; KiB value
    mov di, ART_HDR_X + 17 * 8      ; "Testing memory:  " is 17 chars wide
    mov si, ART_MEM_Y
    mov bl, ART_INK_INDEX
    mov bh, ART_FIELD_INDEX
    call lfb_putdec
    ; " KB" suffix after the 5 digits.
    push cs
    pop ds
    mov si, str_post_kb
    mov di, ART_HDR_X + 23 * 8
    mov ax, ART_MEM_Y
    mov bl, ART_INK_INDEX
    mov bh, ART_FIELD_INDEX
    call lfb_text
    popa
    ret

; gfx_post_note: draw a one-line black status note at the memory-line row,
; first wiping it white. DS:SI = CS-relative ASCIIZ on entry.
gfx_post_note:
    pusha
    push si
    mov di, ART_HDR_X
    mov si, ART_MEM_Y
    mov cx, 256
    mov dx, 8
    mov bl, ART_FIELD_INDEX
    call lfb_fill_rect
    pop si                          ; the note pointer (CS-relative)
    push cs
    pop ds
    mov di, ART_HDR_X
    mov ax, ART_MEM_Y
    mov bl, ART_INK_INDEX
    mov bh, ART_FIELD_INDEX
    call lfb_text
    popa
    ret

str_post_name:     db 'Izarra-BIOS v3.01 - 1997', 0
str_post_starting: db 'Running diagnostics...', 0
; The 0x10 byte is CP437 'BLACK RIGHT-POINTING POINTER' (a filled ► triangle) in
; the 8x8 font, used as a separator between the key and its action.
str_post_hint1:    db 'DEL ', 0x10, ' Configuration menu', 0
str_post_hint2:    db 'TAB ', 0x10, ' Select boot device', 0
str_post_mem:  db 'Testing memory:  ', 0
str_post_kb:   db ' KB', 0
str_post_skip: db 'Memory test skipped', 0

