/target/
/.local/
/izarravm-output/
/compatibility-output/
/corpus-output/
/dev_docs/
*.log
*.tmp
/c_drive/*
!/c_drive/TESTS.COM
!/c_drive/TESTDEV.SYS

# Python bytecode caches from authoring tools
__pycache__/

# FreeDOS kernel build outputs (build-freedos.ps1). The vendored kernel tree's
# own .gitignore already covers *.obj/*.lib/*.exe/*.com/*.bin/*.sys/*.map/config.bat;
# this only adds the owcc .o files the cross-compile (owwin) profile emits, which
# that vendored ignore predates. Shipped artifact is tokados-hdd.img, not these.
toka-dos/freedos/**/*.o
toka-dos/freedos/**/bin/

# FreeCOM build outputs (build-freedos.ps1). The vendored freecom tree's own
# .gitignore covers *.obj/*.lib/*.exe/command.com/*.cln/config.bat/config.mak/
# strings.h/strings.dat, but NOT the per-source *.err diagnostic files wcc drops
# next to each compiled .c. Ignore those, but never the vendored language tables
# (strings/*.err and suppl/src/nls/*.err are committed source, not build output).
toka-dos/freedos/freecom/**/*.err
!toka-dos/freedos/freecom/strings/*.err
!toka-dos/freedos/freecom/suppl/src/nls/*.err

# FreeDOS userland move + sort build outputs (build-freedos.ps1, Open Watcom wcl).
# Only generated files: the .obj wcl emits next to each .c, the linked .exe, the .map
# (-fm), and any *.err wcc diagnostics. The vendored NLS catalogs use language-suffix names
# (move.en, sort.es, ...), NOT *.err, so no language table is at risk here -- but the
# *.err rule is scoped to move/sort and any committed .err table would need a ! below.
toka-dos/freedos/move/**/*.obj
toka-dos/freedos/move/**/*.exe
toka-dos/freedos/move/**/*.map
toka-dos/freedos/sort/**/*.obj
toka-dos/freedos/sort/**/*.exe
toka-dos/freedos/sort/**/*.map
toka-dos/freedos/move/**/*.err
toka-dos/freedos/sort/**/*.err

# TOKAMOUS.COM staged output (build-freedos.ps1). Source is tokamous.asm; only
# the output binary is gitignored (Task 6 image builder reads this path).
toka-dos/build-freedos-tokamous.com
